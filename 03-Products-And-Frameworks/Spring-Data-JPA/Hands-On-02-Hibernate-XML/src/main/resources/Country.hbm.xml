<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping package="com.cognizant.hibernatexml.model">
    <class name="Country" table="country">
        <id name="countryId" column="country_id" type="long">
            <generator class="identity"/>
        </id>
        <property name="countryCode" column="country_code" type="string" not-null="true" unique="true" length="3"/>
        <property name="countryName" column="country_name" type="string" not-null="true" length="100"/>
    </class>
</hibernate-mapping>
